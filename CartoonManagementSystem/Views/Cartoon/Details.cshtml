@model CartoonManagementSystem.Models.Cartoon

<div class="row mt-4">
    <div class="col-md-4">
        <img src="/images/@Model.ImagePath" class="card-img-top" alt="@Model.Name" style="height: 500px; width: 350px;  object-fit: cover;">
    </div>
    <div class="col-md-8">
        <h2>@Model.Name</h2>
        <p class="badge bg-secondary">@Model.Genre</p>
        <hr />
        <p>@Model.Description</p>
        <h4>Rating: ⭐ @Model.AverageRating.ToString("0.0") / 5</h4>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-action="Rate" method="post" class="mt-3">
                <input type="hidden" name="cartoonId" value="@Model.Id" />
                <label for="stars">Leave a Rating:</label>
                <select name="stars" class="form-select d-inline-block w-auto mx-2">
                    <option value="5">5 Stars</option>
                    <option value="4">4 Stars</option>
                    <option value="3">3 Stars</option>
                    <option value="2">2 Stars</option>
                    <option value="1">1 Star</option>
                </select>
                <button type="submit" class="btn btn-warning btn-sm">Submit Rating</button>
            </form>
        }
        else
        {
            <p class="text-muted mt-3">Please <a asp-controller="Account" asp-action="Login">login</a> to leave a rating.</p>
        }
    </div>
</div>