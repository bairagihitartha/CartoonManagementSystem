@model CartoonManagementSystem.Models.Account
@{
    ViewData["Title"] = "Portal Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 me-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white text-center py-3">
                    <h5 class="mb-0"><i class="fas fa-sign-in-alt"></i> User Member Login</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="LoginUser" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email Address</label>
                            <input asp-for="Email" class="form-control" placeholder="Enter user email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Password</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                        </div>
                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" type="checkbox" class="form-check-input" />
                            <label class="form-check-label small" asp-for="RememberMe">Keep me signed in</label>
                        </div>
                        <button type="submit" class="btn btn-success w-100 py-2">Sign In as User</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h5 class="mb-0"><i class="fas fa-lock"></i> Administration Console</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="LoginAdmin" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Admin Email ID</label>
                            <input asp-for="Email" class="form-control" placeholder="Enter admin email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Secure Password</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Enter admin password" />
                        </div>
                        <button type="submit" class="btn btn-dark w-100 py-2">Authorize System Admin</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>