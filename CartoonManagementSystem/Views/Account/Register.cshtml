@model CartoonManagementSystem.Models.Account
@{
    ViewData["Title"] = "Create Account";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 me-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h5 class="mb-0"><i class="fas fa-user"></i> User Sign-Up</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="RegisterUser" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email Address</label>
                            <input asp-for="Email" class="form-control" placeholder="user@domain.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Password</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="6+ characters" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2">Create User Account</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h5 class="mb-0"><i class="fas fa-user-shield"></i> Admin Registry</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="RegisterAdmin" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Admin Email</label>
                            <input asp-for="Email" class="form-control" placeholder="admin@domain.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Secure Password</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Create strong password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-danger w-100 py-2">Create Admin Account</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>